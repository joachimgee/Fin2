# Copy to .env and fill in. .env is gitignored — credentials NEVER reach git.
# All values are read via src.shared.config.require_env() — fail-fast if missing.

# Alpaca (paper keys — https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Polygon.io — backtest/historical data only
POLYGON_API_KEY=

# Anthropic — needed ONLY if config llm.provider is 'anthropic'
# (default provider is 'finbert': local, free, no key — pip install -e '.[finbert]')
ANTHROPIC_API_KEY=

# Redis — event bus + LLM response cache
REDIS_URL=redis://localhost:6379/0

# Telegram — circuit breaker alerts + daily P&L report
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
